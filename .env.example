# Proveedor de captions: openai (predeterminado) o lmstudio.
CAPTION_PROVIDER=openai

# OpenAI. No incluyas este valor en variables NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# LM Studio. El modelo debe ser un VLM (capaz de recibir imágenes).
# LM Studio debe estar iniciado como servidor local. La URL se usa para
# encontrar su API nativa de imágenes en /api/v1/chat.
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_API_KEY=
LM_STUDIO_MODEL=
# Deja espacio para que los modelos con razonamiento interno lleguen al JSON final.
# El adaptador realiza primero este análisis y después genera el caption en JSON.
LM_STUDIO_MAX_OUTPUT_TOKENS=420
LM_STUDIO_FINAL_OUTPUT_TOKENS=180

# Guarda errores del backend en logs/caption-errors.ndjson (sin imágenes ni metadatos).
CAPTION_ERROR_LOGS=true

# Opcionales. Los límites de carga son 75 MB por foto y 500 MB por vídeo.
# Tamaño máximo del lado para la copia WebP interna enviada al modelo.
VISION_MAX_DIMENSION=2048
MAGICK_PATH=magick
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# Identificador respetuoso para Nominatim cuando hay coordenadas GPS.
NOMINATIM_USER_AGENT=luz-texto/1.0
